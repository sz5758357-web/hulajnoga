<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Hulajnogi</title>

<style>

body{
margin:0;
font-family:Arial;
text-align:center;
background:white;
overflow:hidden;
}

.flash{
animation:flash 0.08s infinite;
}

@keyframes flash{
0%{background:white;}
50%{background:red;}
100%{background:white;}
}

.pope{
position:fixed;
width:200px;
height:200px;
object-fit:cover;
z-index:999;
}

</style>
</head>

<body>

<h1>Najlepsze hulajnogi elektryczne</h1>
<p>Kliknij gdziekolwiek</p>

<audio id="sound" loop>
<source src="https://www.soundjay.com/misc/sounds/buzzer-01.mp3">
</audio>

<script>

let started=false
let interval

document.body.onclick=function(){

if(started) return
started=true

document.body.classList.add("flash")

let sound=document.getElementById("sound")
sound.play()

interval=setInterval(function(){

for(let i=0;i<5;i++){

let img=document.createElement("img")

img.src="https://upload.wikimedia.org/wikipedia/commons/1/1d/Pope_Francis_2015.jpg"
img.className="pope"

img.style.left=Math.random()*window.innerWidth+"px"
img.style.top=Math.random()*window.innerHeight+"px"

document.body.appendChild(img)

}

},200)

setTimeout(function(){

document.body.classList.remove("flash")
sound.pause()
sound.currentTime=0
clearInterval(interval)

document.querySelectorAll(".pope").forEach(e=>e.remove())

},180000)

}

</script>

</body>
</html>
